<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive foreground: stylized side profile of the Nomad ND1 — the six-wheeled
  ME:Andromeda rover (three wheels shown per side): raked cockpit canopy, roof
  light bar + antenna, defined wheel arches. Drawn within the 108dp safe zone so
  no launcher mask clips it. Arch cutouts use the Void color to read as gaps
  against the dark icon background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Hull (cyan) -->
    <path android:fillColor="#19B6D0"
        android:pathData="M22,57 L30,49 L42,47 L48,38 L60,38 L66,47 L82,47 L86,50 L87,57 Z" />

    <!-- Wheel arches carved out of the hull -->
    <path android:fillColor="#04100E" android:pathData="M21,62 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z" />
    <path android:fillColor="#04100E" android:pathData="M42,62 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z" />
    <path android:fillColor="#04100E" android:pathData="M63,62 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0 z" />

    <!-- Tires (light cyan) -->
    <path android:fillColor="#7FD6E2" android:pathData="M22.5,62 a10.5,10.5 0 1,0 21,0 a10.5,10.5 0 1,0 -21,0 z" />
    <path android:fillColor="#7FD6E2" android:pathData="M43.5,62 a10.5,10.5 0 1,0 21,0 a10.5,10.5 0 1,0 -21,0 z" />
    <path android:fillColor="#7FD6E2" android:pathData="M64.5,62 a10.5,10.5 0 1,0 21,0 a10.5,10.5 0 1,0 -21,0 z" />

    <!-- Wheel hubs (dark) -->
    <path android:fillColor="#04100E" android:pathData="M29,62 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />
    <path android:fillColor="#04100E" android:pathData="M50,62 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />
    <path android:fillColor="#04100E" android:pathData="M71,62 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 z" />

    <!-- Canopy window (dark, raked) -->
    <path android:fillColor="#04110E" android:pathData="M49,46 L50,40 L58,40 L60,46 Z" />

    <!-- Roof light bar + antenna (bright) -->
    <path android:fillColor="#EAF6F6" android:pathData="M48,38 L48,35.5 L60,35.5 L60,38 Z" />
    <path android:fillColor="#EAF6F6" android:pathData="M56.5,35.5 L56.5,30 L57.5,30 L57.5,35.5 Z" />

    <!-- Headlight (bright) -->
    <path android:fillColor="#EAF6F6" android:pathData="M25,52 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0 z" />
</vector>
